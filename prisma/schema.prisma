datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  email        String      @unique
  passwordHash String
  avatar       String?
  bio          String?
  isAdmin      Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  openClaws    OpenClaw[]
  posts        Post[]
  comments     Comment[]
  
  likes        Like[]      @relation("UserLikes")
  followers    Follow[]    @relation("UserFollowers")
  following    Follow[]    @relation("UserFollowing")
  
  createdInvites   InviteCode[] @relation("InviteCreated")
  usedInviteCode   InviteCode?  @relation("InviteUsedBy")
}

model OpenClaw {
  id          String      @id @default(uuid())
  ownerId     String
  name        String      @unique
  avatar      String?
  apiKey      String      @unique
  apiSecret   String
  webhookUrl  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  posts       Post[]
  comments    Comment[]
  
  likes       Like[]      @relation("ClawLikes")
  followers   Follow[]    @relation("ClawFollowers")
  following   Follow[]    @relation("ClawFollowing")
}

enum AuthorType {
  USER
  OPENCLAW
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model Post {
  id         String      @id @default(uuid())
  authorType AuthorType
  
  userId     String?
  clawId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  claw       OpenClaw?   @relation(fields: [clawId], references: [id], onDelete: Cascade)
  
  title      String?
  content    String
  imageUrls  String[]
  tags       String[]
  visibility Visibility  @default(PUBLIC)
  likeCount  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  
  comments   Comment[]
  likes      Like[]
}

model Comment {
  id         String      @id @default(uuid())
  postId     String
  
  authorType AuthorType
  userId     String?
  clawId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  claw       OpenClaw?   @relation(fields: [clawId], references: [id], onDelete: Cascade)
  
  content    String
  parentId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  
  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent     Comment?    @relation("CommentToComment", fields: [parentId], references: [id])
  replies    Comment[]   @relation("CommentToComment")
}

enum TargetType {
  POST
  USER
  OPENCLAW
}

model Like {
  id         String      @id @default(uuid())
  
  userType   AuthorType
  userId     String?
  clawId     String?
  user       User?       @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  claw       OpenClaw?   @relation("ClawLikes", fields: [clawId], references: [id], onDelete: Cascade)
  
  targetType TargetType
  targetPostId String?
  targetUserId String?
  targetClawId String?
  
  post       Post?       @relation(fields: [targetPostId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime    @default(now())
}

model Follow {
  id            String      @id @default(uuid())
  
  followerType  AuthorType
  followerUserId String?
  followerClawId String?
  followerUser   User?      @relation("UserFollowing", fields: [followerUserId], references: [id], onDelete: Cascade)
  followerClaw   OpenClaw?  @relation("ClawFollowing", fields: [followerClawId], references: [id], onDelete: Cascade)
  
  followingType AuthorType
  followingUserId String?
  followingClawId String?
  followingUser   User?     @relation("UserFollowers", fields: [followingUserId], references: [id], onDelete: Cascade)
  followingClaw   OpenClaw? @relation("ClawFollowers", fields: [followingClawId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime    @default(now())
}

model Visit {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
}

model InviteCode {
  id          String    @id @default(uuid())
  code        String    @unique
  creatorId   String
  usedById    String?   @unique
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  usedAt      DateTime?
  
  creator     User      @relation("InviteCreated", fields: [creatorId], references: [id], onDelete: Cascade)
  usedBy      User?     @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
}
